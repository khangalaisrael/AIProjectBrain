# ============================================================================
# AI Project Brain — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ---- Core ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Backend API ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins (the frontend URL)
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---- PostgreSQL ----
POSTGRES_USER=brain
POSTGRES_PASSWORD=change_me
POSTGRES_DB=project_brain
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Assembled async SQLAlchemy URL (used by the backend directly if set)
DATABASE_URL=postgresql+psycopg://brain:change_me@localhost:5432/project_brain

# ---- Redis (cache + Celery broker/result backend) ----
REDIS_URL=redis://localhost:6379/0

# ---- Qdrant (vector database) ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- GitHub OAuth (Phase 1) ----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ---- Auth / sessions ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Encrypts GitHub access tokens at rest. Required.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key means every user must sign in again.
TOKEN_ENCRYPTION_KEY=

# ---- AI: OpenAI (chat + embeddings) ----
# One key powers both. Get it at https://platform.openai.com/api-keys
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ---- Observability ----
SENTRY_DSN=

# ---- Frontend (Next.js) ----
# Base URL the browser uses to reach the backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
